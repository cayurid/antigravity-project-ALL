{
    "name": "task-manager-backend",
    "version": "1.0.0",
    "description": "Task Manager - Backend API (Express + TypeScript + MySQL)",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:unit": "jest tests/unit",
        "test:integration": "jest tests/integration",
        "test:e2e": "jest tests/e2e",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write 'src/**/*.ts'",
        "db:setup": "tsx src/database/setup.ts",
        "db:migrate": "node_modules/.bin/ts-node src/database/migrate.ts",
        "db:seed": "node_modules/.bin/ts-node src/database/seeds/index.ts",
        "db:reset": "npm run db:migrate && npm run db:seed"
    },
    "keywords": [
        "express",
        "typescript",
        "mysql",
        "task",
        "management"
    ],
    "author": "Clovis",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.3.4",
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^6.7.0",
        "helmet": "^7.0.0",
        "jsonwebtoken": "^9.0.0",
        "morgan": "^1.10.0",
        "mysql2": "^3.2.4",
        "passport": "^0.6.0",
        "passport-github2": "^0.1.12",
        "passport-google-oauth20": "^2.0.0",
        "redis": "^4.6.5",
        "typeorm": "^0.3.15",
        "winston": "^3.8.2",
        "zod": "^3.21.4"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^5.16.5",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jest": "^29.5.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^18.15.11",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^5.59.8",
        "@typescript-eslint/parser": "^5.59.8",
        "eslint": "^8.38.0",
        "husky": "^8.0.3",
        "jest": "^29.5.0",
        "lint-staged": "^13.2.2",
        "nodemon": "^3.1.14",
        "prettier": "^2.8.7",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.1",
        "tsx": "^4.21.0",
        "typescript": "^5.0.4"
    }
}
